}

/* HEADER */

header{
background:linear-gradient(135deg,#6d3b92,#b57ad9);
padding:20px;
position:sticky;
top:0;
z-index:999;
box-shadow:0 3px 10px rgba(0,0,0,.2);
}

nav{
max-width:1200px;
margin:auto;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo-topo{
display:flex;
align-items:center;
gap:10px;
color:white;
font-weight:bold;
}

.logo-topo img{
width:60px;
height:60px;
border-radius:50%;
object-fit:cover;
border:2px solid white;
}

.menu a{
color:white;
text-decoration:none;
margin-left:20px;
font-weight:500;
}

.menu a:hover{
opacity:.8;
}

/* HERO */

.hero{
padding:60px 20px;
max-width:1200px;
margin:auto;

display:grid;
grid-template-columns:1fr 1fr;
gap:40px;
align-items:center;
}

.hero img{
width:100%;
border-radius:25px;
box-shadow:0 10px 30px rgba(0,0,0,.2);
}

.hero-texto h1{
font-size:3rem;
color:#6d3b92;
}

.hero-texto p{
margin-top:20px;
line-height:1.8;
font-size:1.1rem;
}

.btn{
display:inline-block;
margin-top:25px;
padding:15px 30px;
background:#25D366;
color:white;
text-decoration:none;
border-radius:50px;
font-weight:bold;
transition:.3s;
}

.btn:hover{
transform:translateY(-3px);
}

/* SERVIÇOS */

.titulo{
text-align:center;
color:#6d3b92;
margin:60px 0 30px;
font-size:2rem;
}

.servicos{
max-width:1200px;
margin:auto;
padding:0 20px;

display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.card{
background:white;
padding:25px;
border-radius:20px;
box-shadow:0 5px 15px rgba(0,0,0,.08);
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
}

.card h3{
color:#6d3b92;
margin-bottom:10px;
}

/* FORMULÁRIO */

.form-section{
max-width:900px;
margin:60px auto;
padding:30px;
background:white;
border-radius:20px;
box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.form-section h2{
text-align:center;
color:#6d3b92;
margin-bottom:20px;
}

input,
textarea{
width:100%;
padding:15px;
margin-bottom:15px;
border:1px solid #ddd;
border-radius:10px;
}

textarea{
resize:none;
}

button{
width:100%;
padding:15px;
background:#6d3b92;
color:white;
border:none;
border-radius:10px;
font-size:16px;
cursor:pointer;
}

button:hover{
background:#5b2f7c;
}

/* FOOTER */

footer{
background:#6d3b92;
color:white;
text-align:center;
padding:25px;
margin-top:50px;
}

/* WHATSAPP FLUTUANTE */

.whatsapp-fixo{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:white;
width:65px;
height:65px;
border-radius:50%;
display:flex;
justify-content:center;
align-items:center;
font-size:30px;
text-decoration:none;
box-shadow:0 5px 15px rgba(0,0,0,.3);
}

/* RESPONSIVO */

@media(max-width:768px){

.hero{
grid-template-columns:1fr;
text-align:center;
}

.hero-texto h1{
font-size:2.2rem;
}

.menu{
display:none;
}

}

</style>

</head>

